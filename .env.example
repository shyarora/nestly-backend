# Database Configuration
DATABASE_URL=postgresql://postgres:password@localhost:5432/nestly

# Service Ports
API_GATEWAY_PORT=4000
PROPERTY_SERVICE_PORT=4001
AUTH_SERVICE_PORT=4002
BOOKING_SERVICE_PORT=4003
PAYMENT_SERVICE_PORT=4004
REVIEW_SERVICE_PORT=4005
NOTIFICATION_SERVICE_PORT=4006

# Authentication
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
JWT_SECRET=your_super_secret_jwt_key_here_change_in_production

# Payments (Razorpay)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Email Service
SENDGRID_API_KEY=your_sendgrid_api_key
FROM_EMAIL=noreply@nestly.com

# Redis Configuration
REDIS_URL=redis://localhost:6379

# Environment
NODE_ENV=development
LOG_LEVEL=info

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
